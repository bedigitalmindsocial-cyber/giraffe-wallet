# Catalog tool single-password (set in Cloudflare for prod).
CATALOG_PASSWORD=change-me

# Supabase. Leave blank locally to use the in-memory mock store with seed data.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Random 32-byte hex used for HMAC-signing cookies. Generate with:
#   openssl rand -hex 32
SESSION_SECRET=dev-only-not-secure-replace-me-with-random-32-byte-hex

NEXT_PUBLIC_APP_URL=http://localhost:3001
NODE_VERSION=20
